# Spotify app credentials — register at https://developer.spotify.com/dashboard
# Add http://127.0.0.1:8080/api/spotify/callback as a Redirect URI in your Spotify app settings.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional: override server port (default 8080)
PORT=8080

# Comma-separated origins allowed to open the WebSocket. Defaults to localhost
# only — phones/iPads hitting http://heos.local:8080 will be rejected unless
# that origin is listed here. For Pi deployment, add the Pi's mDNS hostname
# AND its LAN IP (mDNS sometimes hiccups; the IP is the fallback):
# WS_ALLOWED_ORIGINS=http://heos.local:8080,http://192.168.1.50:8080
