{
  "name": "heos-controller",
  "version": "0.1.0",
  "private": true,
  "description": "Simple multi-room Spotify controller for HEOS speakers — HeroUI + Tailwind UI",
  "type": "module",
  "scripts": {
    "dev:server": "node --watch server/index.js",
    "dev:web": "vite --config web/vite.config.js",
    "dev": "npm-run-all --parallel dev:server dev:web",
    "build:web": "vite build --config web/vite.config.js",
    "start": "npm run build:web && node server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@heroui/react": "^2.4.6",
    "compression": "^1.8.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "framer-motion": "^11.5.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.1",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.1",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=20"
  }
}
